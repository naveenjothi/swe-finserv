# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sentinel
DB_PASSWORD=sentinel
DB_NAME=sentinel
DB_LOGGING=false
DB_SYNCHRONIZE=false

# RabbitMQ
RMQ_HOST=localhost
RMQ_PORT=5672
RMQ_USER=sentinel
RMQ_PASSWORD=sentinel
RMQ_MGMT_PORT=15672
RMQ_EXCHANGE=sentinel.events
RMQ_DLX=sentinel.dlx

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@sentinel.local
PGADMIN_PASSWORD=admin

# FCA Webhook
FCA_WEBHOOK_SECRET=change-me-in-production
